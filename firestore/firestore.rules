rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ============================================================
    // Agendamentos
    // Leitura: apenas usuários autenticados
    // Escrita: apenas via Admin SDK nas Cloud Functions
    // ============================================================
    match /agendamentos/{id} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // ============================================================
    // Nichos (configurações de segmento)
    // Leitura: pública (necessário para o bot consultar)
    // Escrita: apenas administradores autenticados
    // ============================================================
    match /nichos/{id} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.admin == true;
    }

    // ============================================================
    // Prestadores
    // Leitura: pública (necessário para listar no bot)
    // Escrita: apenas via Admin SDK nas Cloud Functions
    // ============================================================
    match /prestadores/{id} {
      allow read: if true;
      allow write: if false;
    }

    // ============================================================
    // Serviços
    // Leitura: pública (necessário para listar no bot)
    // Escrita: apenas via Admin SDK nas Cloud Functions
    // ============================================================
    match /servicos/{id} {
      allow read: if true;
      allow write: if false;
    }
  }
}
