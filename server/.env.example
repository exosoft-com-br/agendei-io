# Supabase
SUPABASE_URL=https://seu-projeto.supabase.co
SUPABASE_ANON_KEY=sua-anon-key
SUPABASE_SERVICE_ROLE_KEY=sua-service-role-key-secreta

# Servidor
PORT=3000

# CORS - origens adicionais separadas por vírgula (opcional)
# ALLOWED_ORIGINS=https://meusite.com,https://app.meusite.com

# JWT — chave secreta para tokens de autenticação (obrigatória em produção!)
# JWT_SECRET=gere-uma-chave-segura-aqui

# OAuth Google (opcional — habilita login com Google)
# GOOGLE_CLIENT_ID=seu-google-client-id.apps.googleusercontent.com

# OAuth Facebook (opcional — habilita login com Facebook)
# FACEBOOK_APP_ID=seu-facebook-app-id
# FACEBOOK_APP_SECRET=seu-facebook-app-secret

# E-mail SMTP (opcional — para envio de convites de calendário)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=seu-email@gmail.com
# SMTP_PASS=sua-app-password
# SMTP_FROM=Agendamentos <seu-email@gmail.com>

# WhatsApp (preencher quando tiver provedor)
# WHATSAPP_API_URL=https://sua-evolution-api.com
# WHATSAPP_API_TOKEN=seu-token
# WHATSAPP_INSTANCE_NAME=default
# WHATSAPP_PROVIDER=evolution

# Typebot
# TYPEBOT_WEBHOOK_URL=https://typebot.io/api/v1/typebots/xxx/startChat

# Segurança webhook
# WEBHOOK_AUTH_TOKEN=um-token-seguro-qualquer
